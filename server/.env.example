MONGODB_URI=mongodb://127.0.0.1:27017/blog-app
# Use MONGODB_URI=memory for quick local dev without installing MongoDB
PORT=4000
NODE_ENV=development

# Production: your deployed frontend URL
# CLIENT_URL=https://blog-app.vercel.app

# Optional: comma-separated extra allowed origins
# ALLOWED_ORIGINS=https://preview.example.com,https://staging.example.com

# Optional: allow all *.vercel.app preview deployments (default: false)
# ALLOW_VERCEL_PREVIEWS=true
